{
	"name": "cmath-js",
	"homepage": "https://github.com/oskarlh/cmath-js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/oskarlh/cmath-js.git"
	},
	"version": "5.0.0",
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./numbers.js": {
			"default": "./dist/numbers.js",
			"types": "./dist/numbers.d.js"
		}
	},
	"type": "module",
	"author": "Oskar Larsson Högfeldt <oskar@oskar.pm>",
	"contributors": [
		"Oskar Larsson Högfeldt <oskar@oskar.pm>"
	],
	"license": "MIT",
	"description": "C's and C++'s math functions in TypeScript & JavaScript",
	"keywords": [
		"bigint",
		"Bit operations",
		"Bits",
		"C",
		"C++",
		"cmath",
		"cmath-js",
		"double",
		"ECMAScript",
		"float",
		"float64",
		"frexp",
		"gcd",
		"IEEE754",
		"iota",
		"int32",
		"int53",
		"JavaScript",
		"lcm",
		"Math",
		"Mathematics",
		"Maths",
		"NaN",
		"Node",
		"NodeJS",
		"Numbers",
		"Numerics",
		"popcount",
		"signbit",
		"STL",
		"TypeScript"
	],
	"devDependencies": {
   		"@eslint/js": "^10.0.1",
		"@swc/core": "^1",
		"@swc/jest": "^0.2",
		"@types/eslint__js": "^8.42.3",
		"@types/jest": "^30",
		"@types/node": "^24",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"jest": "^30.2.0",
		"prettier": "^3",
		"ts-jest": "^29",
		"typescript": "~5.9",
   		"typescript-eslint": "^8.53.1"
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"lint": "eslint .",
		"lint-fix": "eslint . --fix",
		"prepack": "npm run build",
		"test": "jest",
		"test-with-typechecking": "jest --config=jest.config.with-typechecking.js",
		"typecheck": "tsc --noEmit",
		"verify": "npm run test-with-typechecking --ci && npm run lint && npm run typecheck"
	},
	"files": [
		"dist"
	]
}
